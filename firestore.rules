rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ⚠️ REGLAS DE DESARROLLO (Opción Rápida)
    // Permite leer y escribir a cualquiera.
    // Ideal para prototipos, pero INSEGURO para producción real.
    
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
